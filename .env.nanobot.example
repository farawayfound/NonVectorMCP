# ============================================================
# Nanobot Worker — Environment Configuration
# ============================================================
# Copy to .env.nanobot and fill in the three REQUIRED values below.
# The live .env.nanobot is NOT tracked in git and is NOT touched by any
# deploy script. Your tuned values survive git pull / docker rebuilds.
# ============================================================

# --- REQUIRED: replace <MAC_IP> with the Mac mini's LAN IP ---
# Find it on the Mac: ipconfig getifaddr en0
# Docker on Linux CANNOT resolve mDNS names like macmini.local — always use the IP.

# Redis (same host/port/DB index as the backend .env REDIS_URL).
REDIS_URL=redis://<MAC_IP>:6379/0

# M1 backend URL for delivering completed research.
# Port must match the backend's listen port (see backend/.env PORT, usually 8765).
M1_BASE_URL=http://<MAC_IP>:8765

# Must match the NANOBOT_API_KEY set in the Mac backend's .env.
NANOBOT_API_KEY=

# ============================================================
# Tuned defaults — change only if you know why
# ============================================================

# Ollama (runs in the same docker-compose stack as the worker).
OLLAMA_BASE_URL=http://ollama:11434

# Must exactly match an entry from `ollama list` / GET /api/tags — wrong tag => HTTP 404.
OLLAMA_MODEL=gemma4:26b

# Per-request timeout for Ollama. Streaming is on, so this applies per-token
# (not to the whole response). 3600s is generous.
OLLAMA_TIMEOUT=3600

# KV cache size. On a 32 GB host with gemma4:26b (~16 GB weights) and a 30 GB
# docker mem_limit, 24576 (24k) is the largest value that reliably fits without
# swap-thrash. 65536+ will OOM / silently stall the model load.
OLLAMA_NUM_CTX=24576

# Crawling limits
MAX_SEARCH_RESULTS=10
MAX_CONCURRENT_SCRAPES=4
SCRAPE_TIMEOUT=30

# Worker identity (used in Redis consumer group)
WORKER_ID=nanobot-1

LOG_LEVEL=INFO

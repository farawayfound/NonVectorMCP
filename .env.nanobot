# ============================================================
# Nanobot Worker — Environment Configuration
# ============================================================
# Copy to .env.nanobot and fill in your values.
# ============================================================

# Redis on the Mac mini (same host/port/DB index as the backend's REDIS_URL).
# Docker on Linux usually cannot resolve mDNS names like macmini.local — use the Mac's LAN IP if the worker cannot connect.
REDIS_URL=redis://localhost:6379/0

# M1 backend URL for delivering completed research.
# IMPORTANT: Use the Mac mini's LAN IP address, NOT a hostname like macmini.local.
# mDNS (.local names) does NOT resolve inside a Linux Docker container.
# Find the IP on the Mac with: ipconfig getifaddr en0   (or check Wi-Fi details)
# Example: M1_BASE_URL=http://192.168.1.42:8000
M1_BASE_URL=http://macmini.local:8000

# Must match the NANOBOT_API_KEY set in the M1's .env
NANOBOT_API_KEY=182a4085ce3451d0801fb8c26fca48bc8d92d0179c8097eff1a0d62fa66d3869

# Ollama (runs locally on nanobot via docker-compose)
OLLAMA_BASE_URL=http://ollama:11434
# Fallback model/context — backend Settings (admin_config.json → Redis) is the
# source of truth.  These only apply when Redis hasn't been seeded yet.
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_CTX=65536

# Crawling limits
MAX_SEARCH_RESULTS=10
MAX_CONCURRENT_SCRAPES=4
SCRAPE_TIMEOUT=30

# Worker identity (used in Redis consumer group)
WORKER_ID=nanobot-1

LOG_LEVEL=INFO

# ============================================================
# ChunkyPotato — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set before running.
# ============================================================

SECRET_KEY=change-me-to-a-random-64-char-hex-string   # [REQUIRED] python -c "import secrets; print(secrets.token_hex(32))"
DATA_DIR=./data

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=120
# KV-cache size allocated at model load. Must hold prompt + num_predict.
# For a Quick-level RAG query with 5 chunks × 1200 chars, ~1800 prompt tokens
# + 2048 num_predict ≈ 3900 → 4096 is the safe floor. Raising this to 8192
# roughly doubles prefill time for no quality gain on short RAG queries.
OLLAMA_NUM_CTX=4096

# Chat RAG search depth: Quick (default), Standard, Deep, Exhaustive
CHAT_SEARCH_LEVEL=Quick

# Reasoning trace in chat responses. Off by default: for RAG Q&A the model's
# hidden reasoning rarely improves answers but adds seconds before visible
# text arrives. Set to "true" only when using a model whose quality on this
# workload visibly benefits from thinking.
CHAT_ENABLE_THINKING=false

GITHUB_CLIENT_ID=           # [REQUIRED for admin login] GitHub OAuth App Client ID
GITHUB_CLIENT_SECRET=       # [REQUIRED for admin login] GitHub OAuth App Client Secret
GITHUB_ALLOWED_ADMINS=your-github-username
# Dev only: set to Vite dev server origin so GitHub OAuth redirects back to the
# right frontend after login.  Leave empty (or unset) for production.
FRONTEND_URL=               # e.g. http://localhost:5173 in development

OWNER_NAME=Your Full Name

RELEVANCE_THRESHOLD=15.0
MAX_CONTEXT_CHUNKS=8
CHAT_MAX_TOKENS=2048
CHAT_TEMPERATURE=0.3

PARA_TARGET_TOKENS=300
PARA_OVERLAP_TOKENS=50
MIN_CHUNK_TOKENS=30
CHUNK_QUALITY_MIN_WORDS=15
MAX_ROUTER_SUMMARY_CHARS=3000
MAX_HIERARCHY_DEPTH=6

DEDUPLICATION_INTENSITY=1
ENABLE_CROSS_FILE_DEDUP=false

ENABLE_AUTO_CLASSIFICATION=true
ENABLE_AUTO_TAGGING=true
MAX_TAGS_PER_CHUNK=25
ENABLE_CAMELOT=false

ENABLE_OCR=false
OCR_LANGUAGES=eng
PARALLEL_OCR_WORKERS=4
TESSERACT_PATH=

ENABLE_CROSS_REFERENCES=true
MAX_RELATED_CHUNKS=5
MIN_SIMILARITY_THRESHOLD=0.65

PII_INTERNAL_DOMAINS=

# ── SMTP (required for "Request Access" on the login page) ──
# If SMTP_HOST is empty, /api/auth/request-access returns 503 ("Email service is not configured").
SMTP_HOST=                  # e.g. smtp.gmail.com, smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=                  # SMTP login username (often your email address)
SMTP_PASSWORD=              # SMTP login password or app-specific password
SMTP_FROM=                  # "From" address on outgoing emails (defaults to SMTP_USER)
SMTP_USE_TLS=true           # Use STARTTLS on port 587 (set false only for port 25 relays)

# ── Library (distributed research worker) ──
REDIS_URL=redis://localhost:6379/0
NANOBOT_API_KEY=             # [REQUIRED for Library] shared secret between M1 and nanobot worker

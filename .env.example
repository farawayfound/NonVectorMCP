# ============================================================
# ChunkyPotato — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set before running.
# ============================================================

SECRET_KEY=change-me-to-a-random-64-char-hex-string   # [REQUIRED] python -c "import secrets; print(secrets.token_hex(32))"
DATA_DIR=./data

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Chat RAG search depth: Quick (default), Standard, Deep, Exhaustive
CHAT_SEARCH_LEVEL=Quick

GITHUB_CLIENT_ID=           # [REQUIRED for admin login] GitHub OAuth App Client ID
GITHUB_CLIENT_SECRET=       # [REQUIRED for admin login] GitHub OAuth App Client Secret
GITHUB_ALLOWED_ADMINS=your-github-username

OWNER_NAME=Your Full Name

RELEVANCE_THRESHOLD=15.0
MAX_CONTEXT_CHUNKS=8
CHAT_MAX_TOKENS=2048
CHAT_TEMPERATURE=0.3

PARA_TARGET_TOKENS=300
PARA_OVERLAP_TOKENS=50
MIN_CHUNK_TOKENS=30
CHUNK_QUALITY_MIN_WORDS=15
MAX_ROUTER_SUMMARY_CHARS=3000
MAX_HIERARCHY_DEPTH=6

DEDUPLICATION_INTENSITY=1
ENABLE_CROSS_FILE_DEDUP=false

ENABLE_AUTO_CLASSIFICATION=true
ENABLE_AUTO_TAGGING=true
MAX_TAGS_PER_CHUNK=25
ENABLE_CAMELOT=false

ENABLE_OCR=false
OCR_LANGUAGES=eng
PARALLEL_OCR_WORKERS=4
TESSERACT_PATH=

ENABLE_CROSS_REFERENCES=true
MAX_RELATED_CHUNKS=5
MIN_SIMILARITY_THRESHOLD=0.65

PII_INTERNAL_DOMAINS=
